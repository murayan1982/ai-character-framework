# =========================================
# Required (LLM)
# =========================================

GEMINI_API_KEY=your_gemini_api_key_here


# =========================================
# Optional: Additional LLM Provider
# =========================================

XAI_API_KEY=your_xai_api_key_here


# =========================================
# Optional: Voice Output (ElevenLabs)
# =========================================

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# JSON array of voice objects
VOICE_MASTER=[{"id":"your_voice_id_here","name":"MyVoice"}]

APP_PRESET=text_chat
INPUT_LANGUAGE_CODE=ja
OUTPUT_LANGUAGE_CODE=ja
# =========================================
# Notes
# =========================================

# - Runtime behavior is controlled in config/settings.py
# - VTube Studio token is generated automatically on first run